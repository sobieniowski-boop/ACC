APP_ENV=development
CORS_ORIGINS=http://localhost:3010,http://localhost:5173

# ═══ Redis ═══
REDIS_URL=redis://localhost:6380/0
CELERY_BROKER_URL=redis://localhost:6380/1
CELERY_RESULT_BACKEND=redis://localhost:6380/2

# ═══ Worker Execution (set True to route jobs via Celery) ═══
WORKER_EXECUTION_ENABLED=False

# ═══ ACC Own Database (Azure SQL or local MSSQL) ═══
# When MSSQL_SERVER contains "database.windows.net", pymssql is used (TLS 1.2)
# Otherwise, pyodbc with old "SQL Server" driver
MSSQL_SERVER=192.168.230.120
MSSQL_PORT=11901
MSSQL_USER=
MSSQL_PASSWORD=
MSSQL_DATABASE=NetfoxAnalityka

# ═══ Netfox ERP (read-only, optional — falls back to MSSQL_*) ═══
# Set these when ACC database is split from Netfox ERP
# NETFOX_MSSQL_SERVER=192.168.230.120
# NETFOX_MSSQL_PORT=11901
# NETFOX_MSSQL_USER=Analityka
# NETFOX_MSSQL_PASSWORD=
# NETFOX_MSSQL_DATABASE=NetfoxAnalityka

SP_API_CLIENT_ID=
SP_API_CLIENT_SECRET=
SP_API_REFRESH_TOKEN=
SP_API_SELLER_ID=
SP_API_REGION=eu
SP_API_PRIMARY_MARKETPLACE=A1PA6795UKMFR9

GSHEET_EAN_CSV_URL=
OPENAI_API_KEY=
SECRET_KEY=

DEFAULT_ACTOR=system

# ProductOnboard bridge for Content Ops (restrictions/catalog/push proxy)
PRODUCTONBOARD_BASE_URL=
PRODUCTONBOARD_API_KEY=
PRODUCTONBOARD_TIMEOUT_SEC=20
PRODUCTONBOARD_RESTRICTIONS_PATH=/api/productonboard/restrictions/check
PRODUCTONBOARD_CATALOG_BY_EAN_PATH=/api/productonboard/catalog/search-by-ean
PRODUCTONBOARD_PUSH_PATH=/api/productonboard/acc-content/push
